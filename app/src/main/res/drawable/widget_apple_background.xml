<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Gradient background mimicking Apple Weather's daylight sky style -->
    <gradient
        android:angle="270"
        android:endColor="#1E2A38"
        android:startColor="#8AB7E9" />
    <!-- Rounded corners characteristic of iOS widgets -->
    <corners android:radius="24dp" />
</shape>